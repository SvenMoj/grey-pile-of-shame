# Supabase — copy from your project's API settings at app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Service role key — server-only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin email — only this address can log in to /admin via magic link
ADMIN_EMAIL=your-email@example.com

# Production URL — used to build the magic-link redirect URL
# In development this is derived from request headers automatically
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
